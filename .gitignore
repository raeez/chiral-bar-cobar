# ===========================================================================
#  .gitignore — Modular Koszul Duality (Vol I)
# ===========================================================================

# LaTeX build artifacts
*.aux
*.aux.bak
*.log
*.out
*.toc
*.synctex.gz
*.synctex(busy)
*.fdb_latexmk
*.fls
*.bbl
*.blg
*.nav
*.snm
*.vrb
*.idx
*.ilg
*.ind
*.lof
*.lot
texput.*

# Compiled PDFs (rebuilt by make)
main.pdf
archive/source_tex/*.pdf

# Output directory (rebuilt by make)
out/

# Archive (large, not tracked)
archive/

# OS artifacts
.DS_Store
Thumbs.db

# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/
.pytest-full-state*/

# Build infrastructure
.build_logs/
.build_stamp
*.stdout

# Compute ephemeral
compute/.venv/
compute/.pytest_cache/
compute/state/
compute/verified/

# Claude Code agent infrastructure
.claude/

# Editor
*.swp
*.swo
*~
\#*\#

# Stale debris (gitignored to prevent re-addition)
*.zip
*.xlsx
*.csv
test_snippet.pdf
