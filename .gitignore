# LaTeX build artifacts
*.aux
*.aux.bak
*.log
*.out
*.toc
*.synctex.gz
*.synctex(busy)
*.fdb_latexmk
*.fls
*.bbl
*.blg
*.nav
*.snm
*.vrb
*.idx
*.ilg
*.ind
*.lof
*.lot
texput.*

# Compiled PDFs (built, not tracked)
main.pdf
archive/source_tex/*.pdf

# Output directory (rebuilt by `make`)
out/

# Named release PDFs (manual copies)
Chiral_Bar_Cobar_Duality*.pdf

# Reference library (too large for VCS)
references/*.pdf

# Superseded / archival material
archive/
debris/
*.zip

# External planning docs
*.xlsx

# OS artifacts
.DS_Store
Thumbs.db

# Python / venv
.venv/
__pycache__/
*.pyc
.pytest_cache/
.pytest-full-state*/

# Build infrastructure
.build_logs/
.build_stamp
*.stdout

# Compute ephemeral state
compute/.venv/
compute/.pytest_cache/
compute/state/
compute/verified/

# Editor artifacts
*.swp
*.swo
*~
\#*\#
chapters/frame/preface.tex.backup
test_snippet.pdf
