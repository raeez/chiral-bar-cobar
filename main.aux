\@writefile{lot}{\contentsline {table}{\numberline {J.15}{\ignorespaces Completion kinematics of the standard landscape. $\rho _K = $ Koszul radius (smallest positive root of $G_\mathcal  {A}(t)=1$); $h_K = \log (\rho _K^{-1})$ is the exponential growth rate of reduced-weight bar windows; $\Delta (t)$ is the primitive defect beyond declared generators. Classes: G~(Gaussian, $r_{\max }=2$), L~(Lie/tree, $r_{\max }=3$), C~(contact/quartic, $r_{\max }=4$), M~(mixed, $r_{\max }=\infty $). The $\mathcal  {W}_N$ entropy ladder is monotone increasing with limit $h_K(\mathcal  {W}_\infty ) \approx 0.872$; the $\mathcal  {W}_\infty $ character is governed by the MacMahon plane-partition function (Proposition~\ref {prop:wn-entropy-ladder}).}}{2262}{table.J.15}\protected@file@percent }
\newlabel{tab:completion-kinematics}{{J.15}{2262}{Completion kinematics of the standard landscape. $\rho _K = $ Koszul radius (smallest positive root of $G_\cA (t)=1$); $h_K = \log (\rho _K^{-1})$ is the exponential growth rate of reduced-weight bar windows; $\Delta (t)$ is the primitive defect beyond declared generators. Classes: G~(Gaussian, $r_{\max }=2$), L~(Lie/tree, $r_{\max }=3$), C~(contact/quartic, $r_{\max }=4$), M~(mixed, $r_{\max }=\infty $). The $\Walg _N$ entropy ladder is monotone increasing with limit $h_K(\Walg _\infty ) \approx 0.872$; the $\Walg _\infty $ character is governed by the MacMahon plane-partition function (Proposition~\ref {prop:wn-entropy-ladder})}{table.J.15}{}}
